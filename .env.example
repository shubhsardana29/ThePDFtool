# Copy to .env.local for the Next.js app (never commit .env.local).
# No secrets belong in this file — placeholders only.

# Redis connection for the job queue (docker-compose exposes it on loopback)
REDIS_URL=redis://127.0.0.1:6379

# Where uploaded/processed job files live (auto-cleaned after 1 hour)
STORAGE_DIR=./storage

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Optional OAuth providers; sign-in is hidden when unset.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# ——— Production only (used by docker-compose.prod.yml / deploy.sh) ———
# Your domain(s). Caddy provisions TLS for every listed host automatically
# and 301-redirects www to the apex. Leave unset to serve on http://<vps-ip>.
# SITE_DOMAIN=thepdftool.in, www.thepdftool.in
# NEXT_PUBLIC_SITE_URL=https://thepdftool.in

# Shared-host mode: when another reverse proxy already owns ports 80/443,
# set DEPLOY_MODE=proxy — our Caddy is skipped and the app listens on
# 127.0.0.1:${WEB_PORT} for the host's proxy to forward to. SITE_DOMAIN is
# unused in this mode (TLS is the host proxy's job).
# DEPLOY_MODE=proxy
# WEB_PORT=3020
